{
	"name": "migrate-barrel-imports",
	"version": "1.7.1",
	"description": "A CLI tool to migrate barrel imports in JavaScript/TypeScript monorepos",
	"keywords": [
		"barrel",
		"cli",
		"import",
		"imports",
		"javascript",
		"migrate",
		"monorepo",
		"tool",
		"typescript"
	],
	"homepage": "https://github.com/brandhaug/migrate-barrel-imports#readme",
	"bugs": {
		"url": "https://github.com/brandhaug/migrate-barrel-imports/issues"
	},
	"license": "MIT",
	"author": "Martin Brandhaug",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/brandhaug/migrate-barrel-imports.git"
	},
	"bin": {
		"migrate-barrel-imports": "dist/index.js"
	},
	"files": [
		"dist/"
	],
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"lint": "oxlint --type-aware",
		"format": "oxfmt --write",
		"format:check": "oxfmt --check",
		"prepare": "husky",
		"test": "vitest",
		"validate": "npm run lint && npm run format:check && npm run test"
	},
	"dependencies": {
		"@babel/generator": "7.28.0",
		"@babel/parser": "7.28.0",
		"@babel/traverse": "7.28.0",
		"@babel/types": "7.28.2",
		"commander": "14.0.0",
		"fast-glob": "3.3.3",
		"micromatch": "4.0.8"
	},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@types/babel__generator": "7.27.0",
		"@types/babel__traverse": "7.28.0",
		"@types/micromatch": "4.0.9",
		"execa": "9.6.0",
		"husky": "9.1.7",
		"lint-staged": "16.1.5",
		"oxfmt": "0.44.0",
		"oxlint": "1.59.0",
		"oxlint-tsgolint": "0.20.0",
		"tsx": "4.20.3",
		"typescript": "5.9.2",
		"vitest": "3.2.4"
	},
	"lint-staged": {
		"*.{ts,json}": [
			"oxfmt --write"
		],
		"*.ts": [
			"oxlint --fix --type-aware"
		]
	},
	"engines": {
		"node": ">=20"
	}
}
